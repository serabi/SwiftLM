<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allows the app to use more than the default memory limit on iOS.
         Required for loading 7B+ quantized models without OOM crashes.
         Apple Developer documentation: https://developer.apple.com/documentation/bundleresources/entitlements/com_apple_developer_kernel_increased-memory-limit -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>

    <!-- Background URLSession: keeps model downloads alive when app is backgrounded -->
    <key>UIBackgroundModes</key>
    <array>
        <string>fetch</string>
        <string>processing</string>
    </array>
</dict>
</plist>
